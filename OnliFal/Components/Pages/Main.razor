                        <option value="HautsFrance">Hauts-de-France</option>
                        <option value="ÎleFrance">Île-de-France</option>
                        <option value="Normandie">Normandie</option>
                        <option value="Aquitaine">Nouvelle-Aquitaine</option>
                        <option value="Occitanie">Occitanie</option>
                        <option value="PaysLoire">Pays de la Loire</option>
                        <option value="PACA">Provence-Alpes-Côte d’Azur</option>
                    </select>
                    
                    <button class="h-fit rounded-lg p-2 bg-gray-900 w-fit text-center text-white"  @onclick="resume" >
                        @currentCount
                    </button>
                    <a class="h-fit rounded-lg p-2 bg-gray-900 w-fit text-center text-white"  href="https://www.youtube.com/watch?v=ec0tHV6JA8c&list=RDec0tHV6JA8c&start_radio=1" >
                        ytb
                    </a>
                    <NavLink class="nav-link" href="CreateEvent">
