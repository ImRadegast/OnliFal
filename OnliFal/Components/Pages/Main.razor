@page "/"
@rendermode InteractiveServer
<PageTitle>OnliFAL</PageTitle>



<div class="flex flex-col bg-gray-950 h-dvh p-8 gap-8 items-center">
    <div class="  rounded-lg  w-1/2 m-1/2 p-8 justify-center">
        <p class="text-center text-4xl font-bold text-white">OnliFal</p>
        <br/>
            
                <input type="search" class=" w-full p-4 rounded-lg h-10 border-cyan-300 border-2 bg-gray-800 text-white"  placeholder="Rechercher ... " />
        
      
                <div class="flex flex-row m-2 gap-2">
                    
                    <p id="test" class="h-fit rounded-lg p-2 bg-cyan-300 w-fit text-center text-black">Apéral</p>
